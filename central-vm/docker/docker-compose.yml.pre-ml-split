  # zeek-alias-sync:
  #   build:
  #     context: ./zeek-alias-sync
  #   container_name: zeek-alias-sync
  #   restart: unless-stopped
  #
  #   environment:
  #     OPENSEARCH_URL: "https://opensearch-node1:9200"
