# =============================================================================
# NDR Validator standalone configuration example
# Copy to .env, edit values, then run:
#   docker compose -f docker-compose.standalone.yml up -d --build
# UI:
#   http://localhost:8000
# =============================================================================

VALIDATOR_PORT=8000
APP_ENV=prod
LOG_LEVEL=INFO
SCRAPE_INTERVAL_SECONDS=30
REQUEST_TIMEOUT_SECONDS=5
DATA_DIR=/data
SQLITE_DB_PATH=/data/ndr-validator.db

# Docker network used by your central-vm compose.
# Find it with:
#   docker network ls | grep backend
NDR_DOCKER_NETWORK=central-vm_backend

# =============================================================================
# TLS behavior
# =============================================================================
INSECURE_SKIP_VERIFY=true
CA_CERT_LOCAL_DIR=./certs/ca
CA_CERT_PATH=/certs/ca/ca.crt

# =============================================================================
# OpenSearch
# =============================================================================
OPENSEARCH_URL=https://opensearch-node1:9200
OPENSEARCH_USER=admin
OPENSEARCH_PASSWORD=CHANGE_ME_OPENSEARCH_ADMIN_PASSWORD
OPENSEARCH_VERIFY_SSL=false

# =============================================================================
# OpenSearch Dashboards
# =============================================================================
DASHBOARDS_URL=https://dashboards:5601
DASHBOARDS_USER=admin
DASHBOARDS_PASSWORD=CHANGE_ME_OPENSEARCH_ADMIN_PASSWORD
DASHBOARDS_VERIFY_SSL=false
DASHBOARDS_CHECK_SAVED_OBJECTS=true

# =============================================================================
# Data Prepper
# Metrics/sys endpoint is usually HTTP on port 4900.
# Ingest endpoint is HTTPS on port 2021.
# Leave DATAPREPPER_USER/PASSWORD empty if your management API has no auth.
# =============================================================================
DATAPREPPER_METRICS_URL=https://ndr-dataprepper:4900/metrics/sys
DATAPREPPER_USER=admin
DATAPREPPER_PASSWORD=CHANGE_ME_DATAPREPPER_PASSWORD
DATAPREPPER_VERIFY_SSL=false

DATAPREPPER_INGEST_URL=https://dataprepper:2021/log/ingest
DATAPREPPER_INGEST_USER=vector
DATAPREPPER_INGEST_PASSWORD=vector

# =============================================================================
# Custom NDR services
# =============================================================================
SESSIONIZER_URL=http://ndr-sessionizer:8080
BEHAVIORIZER_URL=http://ndr-behaviorizer:8080
ML_SERVICE_URL=http://ndr-behavior-ml:8080

# =============================================================================
# Vector metrics
# Format:
#   VECTOR_TARGETS=name=url,name=url
# Example:
#   VECTOR_TARGETS=TMSNS01E6=http://10.51.1.12:9598/metrics
# =============================================================================
VECTOR_TARGETS=TMSNS01E6=http://10.51.1.12:9598/metrics
EXPECTED_SENSORS=TMSNS01E6
SENSOR_FIELD_CANDIDATES=sensor.name,sensor,host.name,agent.name

# =============================================================================
# Index patterns
# =============================================================================
ZEEK_INDEX_PATTERN=zeek-*
RAW_INDEX_PATTERN=zeek-logs*
SESSIONS_INDEX_PATTERN=ndr-sessions-*
BEHAVIORS_INDEX_PATTERN=ndr-behaviors-*
FINDINGS_INDEX_PATTERN=ndr-findings-*
ALERTS_INDEX_PATTERN=ndr-alerts*
FLOWS_INDEX_PATTERN=ndr-flows-*
ELASTALERT_STATUS_INDEX_PATTERN=elastalert_status*
ML_MODELS_INDEX_PATTERN=ndr-ml-models*

# =============================================================================
# Detection expectations and thresholds
# =============================================================================
REQUIRED_LOG_TYPES=conn,dns,http,ssl,files,notice,weird,ssh
REQUIRED_RAW_FIELDS=@timestamp,log_type,id.orig_h,id.resp_h
REQUIRED_SESSION_FIELDS=@timestamp,source.ip,destination.ip,network.protocol,network.direction,network.scope,session.log_types
REQUIRED_BEHAVIOR_FIELDS=@timestamp,behavior.entity,features.session_count,quality.data_quality_score,ml.ready

RAW_FRESH_WARN_SECONDS=300
RAW_FRESH_CRIT_SECONDS=900
SESSION_FRESH_WARN_SECONDS=900
SESSION_FRESH_CRIT_SECONDS=1800
BEHAVIOR_FRESH_WARN_SECONDS=1800
BEHAVIOR_FRESH_CRIT_SECONDS=3600
MAX_MISSING_REQUIRED_FIELD_PERCENT=5
MAX_EXCLUDED_SESSION_PERCENT_WARN=80
ML_MIN_READY_BEHAVIORS=20
ML_MAX_UNSCORED_READY_BEHAVIORS=200

# =============================================================================
# Docker runtime checks
# =============================================================================
ENABLE_DOCKER_CHECKS=true
DOCKER_SOCKET=/var/run/docker.sock
EXPECTED_CONTAINERS=os-node-1,ndr-dataprepper,ndr-dashboards,ndr-sessionizer,ndr-behaviorizer,ndr-behavior-ml,elastalert2

# Optional checks
ENABLE_NETFLOW_CHECKS=true
ENABLE_ELASTALERT_CHECKS=true
