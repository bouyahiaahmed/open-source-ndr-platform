          "type": "integer",
          "ignore_malformed": true
        },
        "request_body_len": {
          "type": "long",
          "ignore_malformed": true
        },
        "response_body_len": {
          "type": "long",
          "ignore_malformed": true
        },
        "status_code": {
          "type": "integer",
          "ignore_malformed": true
        },
        "resp_mime_types": {
          "type": "keyword",
          "ignore_above": 4096
        },
        "http": {
          "properties": {
            "request": {
              "properties": {
                "method": {
                  "type": "keyword"
                },
                "body": {
                  "properties": {
                    "bytes": {
                      "type": "long",
                      "ignore_malformed": true
                    }
                  }
                }
              }
            },
            "response": {
              "properties": {
                "status_code": {
                  "type": "integer",
                  "ignore_malformed": true
                }
              }
            }
          }
        },
        "url": {
          "properties": {
            "path": {
              "type": "keyword",
              "ignore_above": 8192
            }
          }
        },
        "user_agent": {
          "properties": {
            "name": {
              "type": "keyword",
              "ignore_above": 8192
            }
          }
        },
        "server_name": {
          "type": "keyword",
          "ignore_above": 8192
        },
        "version": {
          "type": "keyword"
        },
        "cipher": {
          "type": "keyword"
        },
        "cipher_alg": {
          "type": "keyword"
        },
        "curve": {
          "type": "keyword"
        },
        "resumed": {
          "type": "boolean"
        },
        "established": {
          "type": "boolean"
        },
        "ssl_history": {
          "type": "keyword"
        },
