        "rcode_name": {
          "type": "keyword"
        },
        "opcode": {
          "type": "keyword"
        },
        "opcode_name": {
          "type": "keyword"
        },
        "trans_id": {
          "type": "long",
          "ignore_malformed": true
        },
        "rtt": {
          "type": "double",
          "ignore_malformed": true
        },
        "TTLs": {
          "type": "double",
          "ignore_malformed": true
        },
        "AA": {
          "type": "boolean"
        },
        "RA": {
          "type": "boolean"
        },
        "RD": {
          "type": "boolean"
        },
        "TC": {
          "type": "boolean"
        },
        "Z": {
          "type": "long",
          "ignore_malformed": true
        },
        "rejected": {
          "type": "boolean"
        },
        "host": {
          "type": "keyword",
          "ignore_above": 8192
