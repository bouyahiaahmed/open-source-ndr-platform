            "not_valid_before": {
              "type": "double",
              "ignore_malformed": true
            },
            "not_valid_after": {
              "type": "double",
              "ignore_malformed": true
            },
            "key_alg": {
              "type": "keyword"
            },
            "sig_alg": {
              "type": "keyword"
            },
            "key_type": {
              "type": "keyword"
            },
            "key_length": {
              "type": "integer",
              "ignore_malformed": true
            },
            "curve": {
              "type": "keyword"
            },
            "exponent": {
              "type": "keyword"
            }
          }
        },
        "san": {
          "properties": {
            "dns": {
              "type": "keyword",
              "ignore_above": 8192
            }
          }
        },
        "basic_constraints": {
          "properties": {
            "ca": {
              "type": "boolean"
            },
            "path_len": {
              "type": "integer",
              "ignore_malformed": true
            }
          }
        },
        "filename": {
          "type": "keyword",
          "ignore_above": 8192
        },
        "mime_type": {
          "type": "keyword"
        },
        "seen_bytes": {
          "type": "long",
          "ignore_malformed": true
        },
        "total_bytes": {
          "type": "long",
          "ignore_malformed": true
        },
        "missing_bytes": {
          "type": "long",
          "ignore_malformed": true
        },
        "overflow_bytes": {
          "type": "long",
          "ignore_malformed": true
        },
        "md5": {
          "type": "keyword"
        },
        "sha1": {
          "type": "keyword"
        },
        "sha256": {
          "type": "keyword"
        },
        "analyzers": {
          "type": "keyword"
        },
        "depth": {
          "type": "long",
          "ignore_malformed": true
        },
        "is_orig": {
          "type": "boolean"
        },
        "note": {
          "type": "keyword"
        },
        "msg": {
          "type": "keyword",
          "ignore_above": 8192
        },
        "notice": {
          "type": "boolean"
        },
        "peer": {
          "type": "keyword"
        },
        "name": {
          "type": "keyword",
          "ignore_above": 8192
        },
        "path": {
          "type": "keyword",
          "ignore_above": 8192
        },
        "endpoint": {
          "type": "keyword"
        },
        "operation": {
          "type": "keyword"
        },
        "object": {
          "type": "keyword",
          "ignore_above": 8192
        },
        "named_pipe": {
          "type": "keyword"
        },
        "auth_success": {
          "type": "boolean"
        },
        "auth_attempts": {
          "type": "long",
          "ignore_malformed": true
        },
        "username": {
