            }
          }
        },
        "message": {
          "type": "keyword",
          "ignore_above": 8192
        },
        "_test_id": {
          "type": "keyword"
        },
        "validation_status": {
          "type": "keyword"
        },
        "sw_version": {
          "properties": {
            "major": {
              "type": "keyword"
            },
            "minor": {
              "type": "keyword"
            },
            "minor2": {
              "type": "keyword"
            },
            "minor3": {
              "type": "keyword"
            },
            "addl": {
              "type": "keyword",
              "ignore_above": 4096
            }
          }
        },
        "client_addr": {
          "type": "ip",
          "ignore_malformed": true
        },
        "server_addr": {
          "type": "ip",
          "ignore_malformed": true
        },
        "assigned_addr": {
          "type": "ip",
          "ignore_malformed": true
        },
        "data_channel": {
          "properties": {
            "orig_h": {
              "type": "ip",
              "ignore_malformed": true
            },
            "resp_h": {
              "type": "ip",
              "ignore_malformed": true
            },
            "resp_p": {
              "type": "integer",
              "ignore_malformed": true
            },
            "passive": {
              "type": "boolean"
            }
          }
        },
        "lease_time": {
          "type": "double",
          "ignore_malformed": true
        },
        "times": {
