{
  "index_patterns": [
    "zeek-logs",
    "zeek-logs-*",
    "zeek-conn-*",
    "zeek-dns-*",
    "zeek-http-*",
    "zeek-ssl-*",
    "zeek-files-*",
    "zeek-weird-*",
    "zeek-notice-*",
    "zeek-dce_rpc-*",
    "zeek-smb-*",
    "zeek-kerberos-*",
    "zeek-x509-*",
    "zeek-ntlm-*",
    "zeek-ssh-*",
    "zeek-ftp-*",
    "zeek-ldap-*",
    "zeek-other-*"
  ],
  "priority": 500,
  "template": {
    "settings": {
      "number_of_shards": 1,
      "number_of_replicas": 0,
      "refresh_interval": "10s"
    },
    "mappings": {
      "dynamic": true,
      "dynamic_templates": [
        {
          "strings_as_keywords": {
            "match_mapping_type": "string",
            "mapping": {
              "type": "keyword",
              "ignore_above": 8192
            }
          }
        }
      ],
      "properties": {
        "@timestamp": {
          "type": "date"
        },
        "timestamp": {
          "type": "date"
        },
        "ingest_time_vt": {
          "type": "date"
        },
        "ts": {
          "type": "double"
        },
        "sensor": {
          "type": "keyword"
        },
        "log_type": {
          "type": "keyword"
        },
        "log_file": {
          "type": "keyword",
          "ignore_above": 4096
        },
        "file": {
          "type": "keyword",
          "ignore_above": 4096
        },
        "source": {
          "type": "keyword",
          "ignore_above": 4096
        },
        "source_type": {
          "type": "keyword"
        },
        "data_stream": {
          "properties": {
            "type": {
              "type": "keyword"
            },
            "dataset": {
              "type": "keyword"
            }
          }
        },
        "uid": {
          "type": "keyword"
        },
        "fuid": {
          "type": "keyword"
        },
        "community_id": {
          "type": "keyword"
        },
        "id": {
          "properties": {
            "orig_h": {
              "type": "ip",
              "ignore_malformed": true
            },
            "resp_h": {
              "type": "ip",
              "ignore_malformed": true
            },
            "orig_p": {
              "type": "integer",
              "ignore_malformed": true
            },
            "resp_p": {
              "type": "integer",
              "ignore_malformed": true
            }
          }
        },
        "proto": {
          "type": "keyword"
        },
        "ip_proto": {
          "type": "integer",
          "ignore_malformed": true
        },
        "service": {
          "type": "keyword"
        },
        "conn_state": {
          "type": "keyword"
        },
        "history": {
          "type": "keyword"
        },
        "local_orig": {
          "type": "boolean"
        },
        "local_resp": {
          "type": "boolean"
        },
        "duration": {
          "type": "double",
          "ignore_malformed": true
        },
        "orig_bytes": {
          "type": "long",
          "ignore_malformed": true
        },
        "resp_bytes": {
          "type": "long",
          "ignore_malformed": true
        },
        "missed_bytes": {
          "type": "long",
          "ignore_malformed": true
        },
        "orig_pkts": {
          "type": "long",
          "ignore_malformed": true
        },
        "resp_pkts": {
          "type": "long",
          "ignore_malformed": true
        },
        "orig_ip_bytes": {
          "type": "long",
          "ignore_malformed": true
        },
        "resp_ip_bytes": {
          "type": "long",
          "ignore_malformed": true
        },
        "query": {
          "type": "keyword",
          "ignore_above": 8192
        },
        "answers": {
          "type": "keyword",
          "ignore_above": 8192
        },
        "qtype": {
          "type": "integer",
          "ignore_malformed": true
        },
        "qtype_name": {
          "type": "keyword"
        },
        "qclass": {
          "type": "integer",
          "ignore_malformed": true
        },
        "qclass_name": {
          "type": "keyword"
        },
        "rcode": {
          "type": "keyword"
