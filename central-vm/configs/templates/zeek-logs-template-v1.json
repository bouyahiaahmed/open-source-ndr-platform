          "ignore_malformed": true
        },
        "reply_msg": {
          "type": "keyword",
          "ignore_above": 8192
        },
        "request_type": {
          "type": "keyword"
        },
        "success": {
          "type": "boolean"
        },
        "hostname": {
          "type": "keyword",
          "ignore_above": 4096
        },
        "domainname": {
          "type": "keyword",
          "ignore_above": 4096
        },
        "server_nb_computer_name": {
          "type": "keyword",
          "ignore_above": 4096
        },
        "server_dns_computer_name": {
          "type": "keyword",
          "ignore_above": 4096
        },
        "host_key_alg": {
