# Target/victim SSH service
VICTIM_IP=10.51.1.12
SSH_PORT=22

# Known-good credentials for the final successful login
GOOD_USER=vagrant
GOOD_PASS=vagrant

# Number of bad SSH attempts before the valid login
TOTAL_ATTEMPTS=12

# Delay between attempts
SLEEP_SECONDS=1

# Password used for failed attempts
BAD_PASSWORD=wrongpassword

# Bad usernames, comma-separated
BAD_USERS=root,admin,test,ubuntu,azureuser,user,guest,oracle,postgres,deploy,support,backup

# true = perform a valid login after the failed attempts
# false = only failed attempts
DO_VALID_LOGIN=true

# Output folder inside container
OUTPUT_DIR=/results
