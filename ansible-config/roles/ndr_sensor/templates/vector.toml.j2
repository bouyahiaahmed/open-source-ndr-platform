[sinks.zeek_parse_errors_file]
type = "file"
inputs = ["zeek_route_parse.parse_error"]
path = "{{ vector_data_dir }}/zeek-parse-errors-%Y-%m-%d.ndjson"
encoding.codec = "json"

[sinks.dp_ingest]
type = "http"
inputs = ["zeek_mark_pkg_noise"]

uri = "https://{{ dataprepper_host_alias }}:{{ dataprepper_port }}{{ dataprepper_ingest_path }}"
method = "post"

# Send batched events as JSON array
encoding.codec = "json"

# IMPORTANT: do NOT set framing.method
request.headers.Content-Type = "application/json"

auth.strategy = "basic"
auth.user = "{{ dp_basic_user }}"
auth.password = "{{ dp_basic_pass }}"

tls.verify_certificate = true
tls.verify_hostname = false

batch.max_events = 200
batch.timeout_secs = 2

request.timeout_secs = 15
request.retry_attempts = 10
request.retry_initial_backoff_secs = 1
request.retry_max_duration_secs = 120
request.concurrency = 2

buffer.type = "disk"
buffer.max_size = 5368709120
buffer.when_full = "block"
